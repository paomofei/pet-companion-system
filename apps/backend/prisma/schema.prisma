generator client {
  provider = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int       @id @default(autoincrement())
  deviceId          String    @unique @map("device_id") @db.VarChar(64)
  nickname          String    @db.VarChar(20)
  energyBalance     Int       @default(0) @map("energy_balance")
  onboardingOption  Int       @default(0) @map("onboarding_option")
  currentStreak     Int       @default(0) @map("current_streak")
  maxStreak         Int       @default(0) @map("max_streak")
  totalEnergyEarned Int       @default(0) @map("total_energy_earned")
  totalTasksDone    Int       @default(0) @map("total_tasks_done")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  pet          Pet?
  goals        Goal[]
  tasks        Task[]
  templates    TaskTemplate[]
  energyLogs   EnergyLog[]
  wishes       Wish[]
  wishDrawRequests WishDrawRequest[]
  interactions InteractionLog[]
  userBadges   UserBadge[]

  @@map("users")
}

model Pet {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  name        String   @db.VarChar(20)
  level       Int      @default(1)
  currentXp   Int      @default(0) @map("current_xp")
  maxXp       Int      @default(100) @map("max_xp")
  appearance  String   @default("cat_default") @db.VarChar(50)
  pendingDraw Boolean  @default(false) @map("pending_draw")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         User             @relation(fields: [userId], references: [id])
  interactions InteractionLog[]

  @@map("pets")
}

model Goal {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  icon      String    @default("🎯") @db.VarChar(10)
  title     String    @db.VarChar(20)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id])
  tasks     Task[]
  templates TaskTemplate[]

  @@index([userId, deletedAt])
  @@map("goals")
}

model Task {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  goalId        Int?          @map("goal_id")
  title         String        @db.VarChar(50)
  targetDate    String        @map("target_date")
  status        Int           @default(0)
  rewardEnergy  Int           @default(10) @map("reward_energy")
  repeatType    Int           @default(0) @map("repeat_type")
  templateId    Int?          @map("template_id")
  isDelayedCopy Boolean       @default(false) @map("is_delayed_copy")
  completedAt   DateTime?     @map("completed_at")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id])
  goal     Goal?         @relation(fields: [goalId], references: [id])
  template TaskTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId, targetDate, status])
  @@index([goalId, status])
  @@index([templateId, targetDate])
  @@map("tasks")
}

model TaskTemplate {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  goalId       Int?     @map("goal_id")
  title        String   @db.VarChar(50)
  rewardEnergy Int      @default(10) @map("reward_energy")
  repeatType   Int      @map("repeat_type")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id])
  goal  Goal?  @relation(fields: [goalId], references: [id])
  tasks Task[]

  @@index([userId, isActive])
  @@map("task_templates")
}

model EnergyLog {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  actionType   String   @map("action_type") @db.VarChar(20)
  amount       Int
  balanceAfter Int      @map("balance_after")
  refId        Int?     @map("ref_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("energy_logs")
}

model Item {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(20)
  icon       String   @db.VarChar(10)
  costEnergy Int      @map("cost_energy")
  gainXp     Int      @map("gain_xp")
  sortOrder  Int      @default(0) @map("sort_order")

  interactions InteractionLog[]

  @@map("items")
}

model InteractionLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  petId      Int      @map("pet_id")
  itemId     Int      @map("item_id")
  energyCost Int      @map("energy_cost")
  xpGained   Int      @map("xp_gained")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  pet  Pet  @relation(fields: [petId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("interaction_logs")
}

model Wish {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  icon      String    @default("🎁") @db.VarChar(10)
  title     String    @db.VarChar(20)
  weight    Int       @default(10)
  status    Int       @default(0)
  drawnAt   DateTime? @map("drawn_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  drawRequests WishDrawRequest[]

  @@index([userId, status, deletedAt])
  @@index([userId, drawnAt(sort: Desc)])
  @@map("wishes")
}

model WishDrawRequest {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  clientRequestId String   @map("client_request_id") @db.VarChar(64)
  wishId          Int      @map("wish_id")
  poolRemaining   Int      @default(0) @map("pool_remaining")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  wish Wish @relation(fields: [wishId], references: [id])

  @@unique([userId, clientRequestId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("wish_draw_requests")
}

model Badge {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(30)
  name        String   @db.VarChar(20)
  description String   @db.VarChar(100)
  icon        String   @db.VarChar(10)
  category    String   @db.VarChar(20)
  threshold   Int

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  badgeId    Int      @map("badge_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User  @relation(fields: [userId], references: [id])
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}
